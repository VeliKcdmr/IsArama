@model IsArama.Data.Entities.Job
@using IsArama.Web.Helpers

<div>
    <!-- Üst: Logo + Başlık + Şirket -->
    <div class="d-flex gap-3 mb-3">
        <div style="flex-shrink:0;">
            @if (!string.IsNullOrWhiteSpace(Model.Company.LogoUrl))
            {
                <img src="@Model.Company.LogoUrl" alt="@Model.Company.Name"
                     style="width:72px;height:72px;object-fit:contain;border-radius:10px;border:1px solid #e2e8f0;padding:4px;">
            }
            else
            {
                <div style="width:72px;height:72px;border-radius:10px;background:#e2e8f0;display:flex;align-items:center;justify-content:center;font-weight:700;color:#64748b;font-size:1.6em;">
                    @Model.Company.Name.Substring(0, 1).ToUpper()
                </div>
            }
        </div>
        <div class="flex-grow-1 overflow-hidden">
            <h4 class="fw-bold mb-1" style="font-size:1.15em;line-height:1.3;">@Model.Title</h4>
            <div class="fw-semibold text-secondary">@Model.Company.Name</div>
        </div>
    </div>

    <!-- Etiketler -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <span class="badge bg-light text-dark border">
            <i class="bi bi-geo-alt me-1"></i>@Model.City
        </span>
        <span class="badge bg-light text-dark border">
            <i class="bi bi-briefcase me-1"></i>@Model.JobType
        </span>
        <span class="badge bg-light text-dark border">
            <i class="bi bi-tag me-1"></i>@Model.Category.Name
        </span>
        <span class="badge bg-light text-dark border">
            <i class="bi bi-clock me-1"></i>@DateHelper.ToRelative(Model.PublishedAt)
        </span>
        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 ms-auto d-flex align-items-center gap-1">
            <img src="https://www.google.com/s2/favicons?domain=@Model.Source.BaseUrl&sz=16" width="14" height="14" alt="">
            @Model.Source.Name
        </span>
    </div>

    <!-- Açıklama -->
    <div class="border-top pt-3">
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="job-desc">
                @Html.Raw(Model.Description)
            </div>
        }
        else if (Model.Source.Name == "LinkedIn TR")
        {
            <div class="alert alert-light border text-center py-4">
                <i class="bi bi-linkedin fs-2 d-block mb-2" style="color:#0a66c2;"></i>
                <p class="mb-1 fw-semibold">LinkedIn ilanları giriş gerektiriyor.</p>
                <p class="text-muted mb-0 small">Detayları görmek için "İlana Git" butonuna tıklayın.</p>
            </div>
        }
        else
        {
            <div class="alert alert-light border text-center py-4">
                <i class="bi bi-file-text fs-2 d-block mb-2 text-muted"></i>
                <p class="text-muted mb-0">Detaylı açıklama yüklenemedi. Orijinal ilanı ziyaret edin.</p>
            </div>
        }
    </div>
</div>
