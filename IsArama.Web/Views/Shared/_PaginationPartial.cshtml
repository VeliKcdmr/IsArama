@{
    int currentPage = ViewBag.Page;
    int totalPages  = ViewBag.TotalPages;
    int pageSize    = ViewBag.PageSize;
    int total       = ViewBag.Total;

    if (totalPages <= 1) { return; }

    int fromItem = (currentPage - 1) * pageSize + 1;
    int toItem   = Math.Min(currentPage * pageSize, total);

    string PageUrl(int p) =>
        Url.Action("Index", "Jobs", new {
            q          = ViewBag.Q,
            city       = ViewBag.City,
            categoryId = ViewBag.CategoryId,
            jobType    = ViewBag.JobType,
            sourceId   = ViewBag.SourceId,
            page       = p
        })!;
}

<div class="pagination-wrapper">
    <!-- Bilgi satırı -->
    <div class="text-center text-muted small mb-3">
        <span class="fw-semibold text-dark">@fromItem–@toItem</span> arası gösteriliyor
        &nbsp;·&nbsp; toplam <span class="fw-semibold text-primary">@total</span> ilan
        &nbsp;·&nbsp; sayfa <span class="fw-semibold text-dark">@currentPage / @totalPages</span>
    </div>

    <!-- Pagination bar -->
    <nav aria-label="Sayfalama">
        <ul class="pagination pagination-modern justify-content-center gap-1 mb-0 flex-wrap">

            @* İlk sayfa *@
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link page-link-modern" href="@PageUrl(1)" title="İlk sayfa">«</a>
            </li>

            @* Önceki *@
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link page-link-modern" href="@PageUrl(currentPage - 1)" title="Önceki">‹</a>
            </li>

            @* Başta 1 + ellipsis *@
            @if (currentPage > 4)
            {
                <li class="page-item">
                    <a class="page-link page-link-modern" href="@PageUrl(1)">1</a>
                </li>
                @if (currentPage > 5)
                {
                    <li class="page-item disabled">
                        <span class="page-link page-link-modern border-0 bg-transparent px-1">…</span>
                    </li>
                }
            }

            @* Orta pencere: currentPage ±2 *@
            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link page-link-modern @(i == currentPage ? "page-link-active" : "")"
                       href="@PageUrl(i)">@i</a>
                </li>
            }

            @* Sonda ellipsis + son sayfa *@
            @if (currentPage < totalPages - 3)
            {
                @if (currentPage < totalPages - 4)
                {
                    <li class="page-item disabled">
                        <span class="page-link page-link-modern border-0 bg-transparent px-1">…</span>
                    </li>
                }
                <li class="page-item">
                    <a class="page-link page-link-modern" href="@PageUrl(totalPages)">@totalPages</a>
                </li>
            }

            @* Sonraki *@
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link page-link-modern" href="@PageUrl(currentPage + 1)" title="Sonraki">›</a>
            </li>

            @* Son sayfa *@
            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link page-link-modern" href="@PageUrl(totalPages)" title="Son sayfa">»</a>
            </li>

        </ul>
    </nav>
</div>
