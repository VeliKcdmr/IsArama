@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="container py-5 text-center">
    <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:3rem;"></i>
    <h2 class="mt-3 fw-bold">Bir hata oluştu</h2>
    <p class="text-muted">İşleminiz gerçekleştirilemedi. Lütfen daha sonra tekrar deneyin.</p>

    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Hata kodu: <code>@Model.RequestId</code></p>
    }

    <a href="/" class="btn btn-primary mt-2">
        <i class="bi bi-house me-1"></i>Ana Sayfaya Dön
    </a>
</div>
