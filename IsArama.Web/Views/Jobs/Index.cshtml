@model List<IsArama.Data.Entities.Job>
@{
    ViewData["Title"] = "İş İlanları";
    int currentPage = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
}

<div class="container-fluid py-4">
    <div class="row g-4">

        <!-- SOL FİLTRE PANELİ -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm sticky-top" style="top:80px">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-funnel me-2"></i>Filtrele</h5>
                    <form method="get">
                        <!-- Arama -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Arama</label>
                            <input type="text" name="q" value="@ViewBag.Q"
                                   class="form-control" placeholder="Pozisyon veya şirket..." />
                        </div>

                        <!-- Şehir -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Şehir</label>
                            <select name="city" class="form-select">
                                <option value="">Tüm Şehirler</option>
                                @foreach (var city in ViewBag.Cities)
                                {
                                    <option value="@city" selected="@(ViewBag.City == city)">@city</option>
                                }
                            </select>
                        </div>

                        <!-- Kategori -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Kategori</label>
                            <select name="categoryId" class="form-select">
                                <option value="">Tüm Kategoriler</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id" selected="@(ViewBag.CategoryId == cat.Id)">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <!-- İş Tipi -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">İş Tipi</label>
                            <select name="jobType" class="form-select">
                                <option value="">Tümü</option>
                                <option value="Tam Zamanlı" selected="@(ViewBag.JobType == "Tam Zamanlı")">Tam Zamanlı</option>
                                <option value="Yarı Zamanlı" selected="@(ViewBag.JobType == "Yarı Zamanlı")">Yarı Zamanlı</option>
                                <option value="Uzaktan" selected="@(ViewBag.JobType == "Uzaktan")">Uzaktan</option>
                                <option value="Staj" selected="@(ViewBag.JobType == "Staj")">Staj</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-1"></i>Filtrele
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-x-circle me-1"></i>Temizle
                        </a>
                    </form>
                </div>
            </div>
        </div>

        <!-- SAĞ İLAN LİSTESİ -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">
                    <span class="text-primary">@ViewBag.Total</span> ilan bulundu
                </h5>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-search fs-1 d-block mb-3"></i>
                    <h5>İlan bulunamadı</h5>
                    <p class="text-muted">Farklı filtreler deneyin.</p>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var job in Model)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm job-card"
                                 style="cursor:pointer"
                                 data-job-id="@job.Id"
                                 data-bs-toggle="modal"
                                 data-bs-target="#jobModal">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="badge bg-primary">@job.Source.Name</span>
                                        <span class="badge bg-light text-dark border">@job.JobType</span>
                                    </div>
                                    <h6 class="fw-bold mb-1">@job.Title</h6>
                                    <p class="text-muted small mb-2">@job.Company.Name</p>
                                    <div class="d-flex gap-3 text-muted small">
                                        <span><i class="bi bi-geo-alt me-1"></i>@job.City</span>
                                        <span><i class="bi bi-tag me-1"></i>@job.Category.Name</span>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-0 text-muted small">
                                    <i class="bi bi-clock me-1"></i>@DateHelper.ToRelative(job.PublishedAt)
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- SAYFALAMA -->
                @if (totalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                       asp-route-q="@ViewBag.Q"
                                       asp-route-city="@ViewBag.City"
                                       asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-jobType="@ViewBag.JobType"
                                       asp-route-page="@(currentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-q="@ViewBag.Q"
                                       asp-route-city="@ViewBag.City"
                                       asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-jobType="@ViewBag.JobType"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                       asp-route-q="@ViewBag.Q"
                                       asp-route-city="@ViewBag.City"
                                       asp-route-categoryId="@ViewBag.CategoryId"
                                       asp-route-jobType="@ViewBag.JobType"
                                       asp-route-page="@(currentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

<!-- JOB DETAIL MODAL -->
<div class="modal fade" id="jobModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalTitle">İlan Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <a id="modalOriginalUrl" href="#" target="_blank" class="btn btn-primary">
                    <i class="bi bi-box-arrow-up-right me-1"></i>İlana Git
                </a>
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/jobModal.js"></script>
}
