<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="IsArama.Mobile.Pages.JobDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:IsArama.Mobile.ViewModels"
    xmlns:models="clr-namespace:IsArama.Mobile.Models"
    Title=""
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Mavi Header ── -->
        <Grid Grid.Row="0" BackgroundColor="{StaticResource PrimaryDark}"
              Padding="16,48,16,14" ColumnDefinitions="Auto,*,Auto">

            <!-- Geri butonu -->
            <Border Grid.Column="0"
                    BackgroundColor="rgba(255,255,255,0.18)"
                    Stroke="rgba(255,255,255,0.25)"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="12,7"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="❮" FontSize="15" TextColor="White" VerticalOptions="Center" LineHeight="1" />
                    <Label Text="Geri" FontSize="15" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" LineHeight="1" />
                </HorizontalStackLayout>
            </Border>

            <Label Grid.Column="1"
                   Text="İlan Detayı"
                   FontSize="17" FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"
                   Margin="12,0,0,0" />
        </Grid>

        <!-- ── İçerik ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- Yükleniyor -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   Margin="0,40"
                                   HorizontalOptions="Center" />

                <!-- İçerik (yüklendikten sonra) -->
                <VerticalStackLayout IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                     Spacing="10" Padding="12,10,12,20">

                    <!-- Şirket + Başlık kartı -->
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Border}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="14">
                        <Grid ColumnDefinitions="60,*" ColumnSpacing="12">
                            <!-- Logo -->
                            <Grid Grid.Column="0"
                                  WidthRequest="54" HeightRequest="54">
                                <Border IsVisible="{Binding Job.HasLogo}"
                                        Stroke="{StaticResource Border}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="4">
                                    <Image Source="{Binding Job.CompanyLogo}"
                                           Aspect="AspectFit"
                                           WidthRequest="46" HeightRequest="46" />
                                </Border>
                                <Border IsVisible="{Binding Job.HasLogo, Converter={StaticResource InverseBool}}"
                                        BackgroundColor="{Binding Job.LogoColor}"
                                        Stroke="{StaticResource Border}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 12">
                                    <Label Text="{Binding Job.Initials}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           TextColor="#475569" />
                                </Border>
                            </Grid>

                            <!-- Başlık + Şirket -->
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="3">
                                <Label Text="{Binding Job.Title}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding Job.Company}"
                                       FontSize="13"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Etiketler -->
                    <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center"
                                JustifyContent="Start">
                        <Border BackgroundColor="{StaticResource Background}"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                Padding="8,4" Margin="0,0,6,5">
                            <Label Text="{Binding Job.City, StringFormat='📍 {0}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource Background}"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                Padding="8,4" Margin="0,0,6,5">
                            <Label Text="{Binding Job.JobType, StringFormat='💼 {0}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource Background}"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                Padding="8,4" Margin="0,0,6,5">
                            <Label Text="{Binding Job.TimeAgo, StringFormat='🕐 {0}'}"
                                   FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        </Border>
                        <Border BackgroundColor="{StaticResource PrimaryLight}"
                                Stroke="#bfdbfe"
                                StrokeThickness="1" StrokeShape="RoundRectangle 8"
                                Padding="8,4" Margin="0,0,6,5">
                            <Label Text="{Binding Job.Source, StringFormat='🌐 {0}'}"
                                   FontSize="12" TextColor="{StaticResource Primary}" />
                        </Border>
                    </FlexLayout>

                    <!-- Açıklama kartı -->
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Border}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="14">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="İlan Açıklaması"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Border}" />

                            <!-- Açıklama yok mesajı -->
                            <Label IsVisible="{Binding HasDescription, Converter={StaticResource InverseBool}}"
                                   Text="Açıklama bulunamadı. Orijinal ilanı ziyaret edin."
                                   FontSize="13"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalTextAlignment="Center"
                                   Padding="0,8" />

                            <!-- Açıklama WebView -->
                            <WebView x:Name="DescriptionWebView"
                                     IsVisible="{Binding HasDescription}"
                                     HeightRequest="200"
                                     Navigated="OnDescriptionWebViewNavigated" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- İlana Git butonu -->
                    <Border BackgroundColor="{StaticResource Primary}"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 14"
                            Padding="0,14"
                            Margin="0,4,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenUrlCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label Text="🔗" FontSize="16" VerticalOptions="Center" />
                            <Label Text="Orijinal İlana Git"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
